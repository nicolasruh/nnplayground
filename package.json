{
  "name": "vanilla",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "build": "webpack --mode production",
    "check:unused": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "watch": "webpack --mode development --watch",
    "start": "npm run build && http-server . -p 8080",
    "dev": "concurrently \"npm run watch\" \"http-server . -p 8080\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.86.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@types/lodash": "^4.14.110",
    "linear-algebra": "^3.1.4",
    "lodash": "^4.17.10"
  }
}
